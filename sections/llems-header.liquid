{% comment %}
  LLEMS Header
  ============================================================
  Minimal header: 4-item navigation in a 4-column layout.
  Designed to be portable across Shopify themes.
{% endcomment %}

{{ 'llems-home.css' | asset_url | stylesheet_tag }}

<header
  class="llems-header color-{{ section.settings.color_scheme }} gradient"
  style="
    --llems-header-padding-top: {{ section.settings.padding_top }}px;
    --llems-header-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="llems-header__inner">
    <nav class="llems-header__nav" aria-label="Navigation">
      <ul class="llems-header__list">
        <li class="llems-header__item">
          <a href="/collections/all" class="llems-header__link">Catalog</a>
        </li>
        <li class="llems-header__item">
          <a href="/pages/collaboration" class="llems-header__link">Collaboration</a>
        </li>
        <li class="llems-header__item">
          <a href="/pages/about" class="llems-header__link">About LLEMS</a>
        </li>
        <li class="llems-header__item">
          <a href="{{ routes.cart_url }}" class="llems-header__link" data-llems-cart-link>Cart (0)</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "LLEMS Header",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "LLEMS Header"
    }
  ]
}
{% endschema %}
