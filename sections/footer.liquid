{% comment %}
  LLEMS minimal footer
{% endcomment %}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <p class="llems-footer-tagline">A Blend of Scent and Chinese typography.<br>Inspired by Eastern Philosophy.</p>
    <ul class="llems-footer-links">
      <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
      <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
      <li><a href="https://instagram.com/llems" target="_blank" rel="noopener">Instagram</a></li>
      <li><a href="/pages/contact">Contacts</a></li>
    </ul>
  </div>
</footer>

{% style %}
  .llems-footer-tagline {
    margin: 0 0 2rem;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300;
    line-height: 1.25;
    opacity: 0.85;
  }
  .llems-footer-links {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 1.2rem;
  }
  .llems-footer-links a {
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
  }
  .llems-footer-links a:hover {
    text-decoration: underline;
  }
{% endstyle %}
