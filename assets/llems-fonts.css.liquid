/* ------------------------------------------------------------
   LLEMS Fonts
   ------------------------------------------------------------ */
@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "Kleukens-EgyptienneRegular.woff2" | asset_url }}') format('woff2'),
       url('{{ "Kleukens-EgyptienneRegular.otf" | asset_url }}') format('opentype');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "Kleukens-EgyptienneRegularItalic.woff2" | asset_url }}') format('woff2'),
       url('{{ "Kleukens-EgyptienneRegularItalic.otf" | asset_url }}') format('opentype');
  font-weight: 400;
  font-style: italic;
  font-display: swap;
}

@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "Kleukens-EgyptienneBook.woff2" | asset_url }}') format('woff2'),
       url('{{ "Kleukens-EgyptienneBook.otf" | asset_url }}') format('opentype');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "Kleukens-EgyptienneBookItalic.woff2" | asset_url }}') format('woff2'),
       url('{{ "Kleukens-EgyptienneBookItalic.otf" | asset_url }}') format('opentype');
  font-weight: 300;
  font-style: italic;
  font-display: swap;
}

@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "Kleukens-EgyptienneMedium.woff2" | asset_url }}') format('woff2'),
       url('{{ "Kleukens-EgyptienneMedium.otf" | asset_url }}') format('opentype');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}

html,
body,
h1, h2, h3, h4, h5, h6 {
  font-family: 'Kleukens-Egyptienne', Georgia, serif;
  letter-spacing: -0.02em;
  word-spacing: -0.02em;
}
