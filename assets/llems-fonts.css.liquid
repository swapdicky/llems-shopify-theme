/* ------------------------------------------------------------
   LLEMS Fonts
   ------------------------------------------------------------ */
@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "kleukens-egyptienne-regular.woff2" | asset_url }}') format('woff2'),
       url('{{ "kleukens-egyptienne-regular.woff" | asset_url }}') format('woff');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Kleukens-Egyptienne';
  src: url('{{ "kleukens-egyptienne-bold.woff2" | asset_url }}') format('woff2'),
       url('{{ "kleukens-egyptienne-bold.woff" | asset_url }}') format('woff');
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}

.llems-header,
.llems-home,
.llems-footer,
.llems-cart-drawer {
  font-family: 'Kleukens-Egyptienne', sans-serif;
}
